<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Data Table</title>
</head>
<body>

<h1>Data List</h1>

<table border="1">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
        </tr>
    </thead>

    <tbody>
        <% data.forEach((e) => { %>
            <tr>
                <td><%= e.id %></td>
                <td><%= e.name %></td>
            </tr>
        <% }) %>
    </tbody>
</table>

</body>
</html>