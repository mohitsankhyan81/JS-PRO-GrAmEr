<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <table>
        <tr>
            <th>Id</th>
            <th>Name</th>
        </tr>
        <tr>
            <% userdata.forEach((e)=>{ %>
                <td><%= e.id %></td>
                <td><%= e.name %></td>
            <%})%>
        </tr>
    </table>    
</body>
</html>